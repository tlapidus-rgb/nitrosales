{
  "regions": ["gru1"],
  "functions": {
    "app/api/sync/**/*": {
      "maxDuration": 800
    },
    "app/api/cron/**/*": {
      "maxDuration": 800
    }
  },
  "crons": [
    {
      "path": "/api/sync?key=nitrosales-secret-key-2024-production",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/sync/chain?key=nitrosales-secret-key-2024-production",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/anomalies?key=nitrosales-secret-key-2024-production",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/digest?key=nitrosales-secret-key-2024-production",
      "schedule": "0 10 * * 1"
    },
    {
      "path": "/api/sync/gsc?key=nitrosales-secret-key-2024-production",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/sync/competitors?key=nitrosales-secret-key-2024-production",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/ml-missed-feeds?key=nitrosales-secret-key-2024-production",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/ml-reconcile?key=nitrosales-secret-key-2024-production",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/ml-reconcile?key=nitrosales-secret-key-2024-production&mode=deep",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/influencer-summary?key=nitrosales-secret-key-2024-production",
      "schedule": "0 10 1 * *"
    },
    {
      "path": "/api/cron/ads-utm-audit?key=nitrosales-secret-key-2024-production",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/exchange-rates?key=nitrosales-secret-key-2024-production",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/inflation-index?key=nitrosales-secret-key-2024-production",
      "schedule": "0 13 16 * *"
    },
    {
      "path": "/api/cron/alerts-scheduler?key=nitrosales-secret-key-2024-production",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/control-alerts?key=nitrosales-secret-key-2024-production",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/backfill-runner?key=nitrosales-secret-key-2024-production",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/meta-token-refresh?key=nitrosales-secret-key-2024-production",
      "schedule": "0 5 * * *"
    }
  ]
}
