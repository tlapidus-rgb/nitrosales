// ══════════════════════════════════════════════════════════════
// NITROSALES - Esquema de Base de Datos
// ══════════════════════════════════════════════════════════════
// Este archivo define TODA la estructura de datos de NitroSales.
// Prisma lo convierte automáticamente en tablas de PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─────────────────────────────────────────────
// USUARIOS Y AUTENTICACIÓN
// ─────────────────────────────────────────────

// Cada organización/empresa que usa NitroSales
model Organization {
  id        String   @id @default(cuid())
  name      String                          // "El Mundo del Juguete"
  slug      String   @unique                // "el-mundo-del-juguete" (para URLs)
  plan      Plan     @default(STARTER)      // Plan de suscripción
  settings  Json     @default("{}")         // Config flexible: { nitroWeights: { first: 30, last: 40, middle: 30 } }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  connections Connection[]
  orders      Order[]
  products    Product[]
  customers   Customer[]
  adCampaigns              AdCampaign[]
  adMetrics                AdMetricDaily[]
  adCreatives              AdCreative[]
  adCreativeMetrics        AdCreativeMetricDaily[]
  adCreativeClassifications AdCreativeClassification[]
  adSets                   AdSet[]
  adSetMetrics             AdSetMetricDaily[]
  webMetrics               WebMetricDaily[]
  funnelData  FunnelDaily[]
  botChats    BotChat[]
  botMemories BotMemory[]
  insights    Insight[]
  pixelVisitors            PixelVisitor[]
  pixelEvents              PixelEvent[]
  pixelAttributions        PixelAttribution[]
  seoQueryDaily            SeoQueryDaily[]
  seoPageDaily             SeoPageDaily[]
  competitorStores         CompetitorStore[]
  competitorPrices         CompetitorPrice[]
  competitorAds            CompetitorAd[]
  // MercadoLibre
  mlListings               MlListing[]
  mlQuestions              MlQuestion[]
  mlSellerMetrics          MlSellerMetricDaily[]
  mlShipments              MlShipment[]
  mlAdCampaigns            MlAdCampaignDaily[]
  mlCommissions            MlCommission[]
  manualCosts              ManualCost[]
  shippingRates            ShippingRate[]
  ltvPredictions           CustomerLtvPrediction[]
  // Influencer Marketing
  influencers              Influencer[]
  influencerCampaigns      InfluencerCampaign[]
  influencerAttributions   InfluencerAttribution[]
  influencerCoupons        InfluencerCoupon[]
  influencerApplications   InfluencerApplication[]
  influencerBriefings      InfluencerBriefing[]
  contentSubmissions       ContentSubmission[]
  productSeedings          ProductSeeding[]
  // Audience Sync
  audiences                Audience[]

  @@map("organizations")
}

enum Plan {
  STARTER
  GROWTH
  PRO
}

// Usuarios que acceden a NitroSales
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String
  role           UserRole  @default(MEMBER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  botChats       BotChat[]

  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

// ─────────────────────────────────────────────
// CONEXIONES A PLATAFORMAS EXTERNAS
// ─────────────────────────────────────────────

// Cada "enchufe" que conecta NitroSales con una plataforma
model Connection {
  id             String           @id @default(cuid())
  platform       Platform                        // VTEX, SHOPIFY, GA4, etc.
  status         ConnectionStatus @default(PENDING)
  credentials    Json                            // Credenciales encriptadas
  lastSyncAt     DateTime?  @db.Timestamptz       // Última vez que se trajeron datos
  lastSyncError  String?                         // Si falló, qué pasó
  lastSuccessfulSyncAt DateTime? @db.Timestamptz
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, platform])
  @@map("connections")
}

enum Platform {
  VTEX
  SHOPIFY
  TIENDANUBE
  WOOCOMMERCE
  MERCADOLIBRE
  GA4
  GOOGLE_ADS
  META_ADS
  TIKTOK_ADS
  GOOGLE_SEARCH_CONSOLE
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  ERROR
  DISCONNECTED
}

// ─────────────────────────────────────────────
// DATOS DE ECOMMERCE (vienen de VTEX/Shopify/etc)
// ─────────────────────────────────────────────

// Cada orden/pedido
model Order {
  id              String      @id @default(cuid())
  externalId      String                          // ID en VTEX/Shopify
  status          OrderStatus
  totalValue      Decimal     @db.Decimal(12, 2)  // Valor total en la moneda del ecommerce
  currency        String      @default("ARS")
  itemCount       Int                             // Cantidad de productos
  source          String      @default("VTEX")    // Plataforma origen: VTEX, MELI
  channel         String?                         // Canal de venta (web, app, marketplace)
  trafficSource   String?                         // De dónde vino (organic, paid, direct, etc)
  paymentMethod   String?
  shippingCost    Decimal?    @db.Decimal(12, 2)
  discountValue   Decimal?    @db.Decimal(12, 2)
  couponCode      String?                         // Código de cupón usado (de VTEX marketingData.coupon)
  promotionNames  String?                         // Nombres de promociones aplicadas (de VTEX ratesAndBenefitsData/priceTags)
  deliveryType    String?                         // "pickup" | "shipping" — inferred from VTEX logisticsInfo
  pickupStoreName String?                         // Nombre amigable de la sucursal (si es retiro)
  postalCode      String?                         // CP destino, de VTEX shippingData.address
  shippingCarrier String?                         // Mensajería usada (ANDREANI, OCA, etc.)
  shippingService String?                         // Tipo de servicio (ESTANDAR, EXPRESS)
  realShippingCost Decimal? @db.Decimal(12, 2)   // Costo real calculado desde tabla de tarifas
  deviceType      String?                         // mobile, desktop, tablet
  orderDate       DateTime    @db.Timestamptz      // Fecha del pedido (UTC from VTEX)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @default(now()) @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  customerId      String?
  customer        Customer?    @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  pixelAttributions PixelAttribution[]
  influencerAttributions InfluencerAttribution[]

  @@unique([organizationId, externalId])
  @@index([organizationId, orderDate])
  @@index([organizationId, source, orderDate])
  @@index([organizationId, trafficSource])
  @@index([organizationId, customerId])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  APPROVED
  INVOICED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

// Productos dentro de cada orden
model OrderItem {
  id          String @id @default(cuid())
  quantity    Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  costPrice   Decimal? @db.Decimal(12, 2)  // Costo unitario al momento de la orden (snapshot de Product.costPrice)

  orderId     String
  order       Order   @relation(fields: [orderId], references: [id])
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// Catálogo de productos
model Product {
  id            String   @id @default(cuid())
  externalId    String                           // ID en VTEX/Shopify
  name          String
  sku           String?
  ean           String?                            // EAN/GTIN-13 barcode
  category      String?
  brand         String?
  price         Decimal  @db.Decimal(12, 2)
  costPrice     Decimal? @db.Decimal(12, 2)      // Costo de compra al proveedor (COGS)
  compareAtPrice Decimal? @db.Decimal(12, 2)     // Precio tachado/anterior
  imageUrl      String?
  isActive      Boolean  @default(true)
  stock          Int?                            // Unidades disponibles en VTEX
  stockUpdatedAt DateTime?                       // Última sincronización de stock
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  orderItems     OrderItem[]
  competitorPrices CompetitorPrice[]
  productSeedings  ProductSeeding[]

  @@unique([organizationId, externalId])
  @@map("products")
}

// Clientes/compradores
model Customer {
  id            String   @id @default(cuid())
  externalId    String                           // ID en VTEX/Shopify
  email         String?
  firstName     String?
  lastName      String?
  city          String?
  state         String?
  country       String?
  firstOrderAt  DateTime?   @db.Timestamptz       // Fecha de primera compra
  lastOrderAt   DateTime?   @db.Timestamptz      // Fecha de última compra
  totalOrders   Int      @default(0)             // Cantidad total de compras
  totalSpent    Decimal  @default(0) @db.Decimal(12, 2) // Gasto total acumulado
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  orders         Order[]
  pixelVisitors  PixelVisitor[]
  ltvPredictions CustomerLtvPrediction[]

  @@unique([organizationId, externalId])
  @@index([organizationId, lastOrderAt])
  @@map("customers")
}

// ─────────────────────────────────────────────
// DATOS DE PUBLICIDAD (Meta Ads + Google Ads)
// ─────────────────────────────────────────────

// Campañas publicitarias
model AdCampaign {
  id            String     @id @default(cuid())
  externalId    String                           // ID en Meta/Google
  platform      AdPlatform                       // META o GOOGLE
  name          String
  status        String                           // ACTIVE, PAUSED, etc.
  objective     String?                          // CONVERSIONS, TRAFFIC, etc.
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  dailyMetrics   AdMetricDaily[]
  adCreatives    AdCreative[]
  adSets         AdSet[]
  pixelAttributions PixelAttribution[]

  @@unique([organizationId, externalId, platform])
  @@map("ad_campaigns")
}

// Ad Set (Meta) / Ad Group (Google) — nivel intermedio entre Campaign y Ad
model AdSet {
  id            String     @id @default(cuid())
  externalId    String                           // ID del ad set/ad group en la plataforma
  platform      AdPlatform
  name          String
  status        String     @default("ACTIVE")    // ACTIVE, PAUSED, REMOVED
  bidStrategy   String?                          // CBO, ABO, tCPA, tROAS, etc.
  dailyBudget   Decimal?   @db.Decimal(12, 2)    // Presupuesto diario si aplica
  targetingInfo String?                          // Info resumida del targeting (JSON o texto)
  optimizationGoal String?                       // CONVERSIONS, LINK_CLICKS, IMPRESSIONS, etc.

  // Metricas agregadas (se calculan en sync)
  campaignId     String
  campaign       AdCampaign @relation(fields: [campaignId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  adCreatives    AdCreative[] @relation("AdSetCreatives")
  dailyMetrics   AdSetMetricDaily[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, externalId, platform])
  @@index([campaignId])
  @@index([organizationId, platform])
  @@map("ad_sets")
}

// Metricas diarias a nivel Ad Set / Ad Group
model AdSetMetricDaily {
  id              String     @id @default(cuid())
  date            DateTime   @db.Date
  platform        AdPlatform
  impressions     Int        @default(0)
  clicks          Int        @default(0)
  spend           Decimal    @default(0) @db.Decimal(12, 2)
  conversions     Int        @default(0)
  conversionValue Decimal    @default(0) @db.Decimal(12, 2)
  reach           Int?
  frequency       Float?

  adSetId         String
  adSet           AdSet @relation(fields: [adSetId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([adSetId, date])
  @@index([organizationId, date])
  @@index([organizationId, platform, date])
  @@map("ad_set_metrics_daily")
}

enum AdPlatform {
  META
  GOOGLE
  TIKTOK
}

// Métricas diarias de publicidad (un registro por campaña por día)
model AdMetricDaily {
  id              String     @id @default(cuid())
  date            DateTime   @db.Date             // El día
  platform        AdPlatform
  impressions     Int        @default(0)          // Veces que se mostró
  clicks          Int        @default(0)          // Clics
  spend           Decimal    @default(0) @db.Decimal(12, 2) // Gasto en USD/moneda
  conversions     Int        @default(0)          // Compras atribuidas
  conversionValue Decimal    @default(0) @db.Decimal(12, 2) // Revenue atribuido
  reach           Int?                            // Personas únicas alcanzadas (Meta)
  frequency       Float?                          // Frecuencia promedio (Meta)
  qualityScore    Float?                          // Quality Score (Google)
  impressionShare Float?                          // Impression Share (Google)

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  campaignId      String
  campaign        AdCampaign   @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, date])
  @@index([organizationId, date])
  @@index([organizationId, platform, date])
  @@map("ad_metrics_daily")
}

// ─────────────────────────────────────────────
// ANUNCIOS / CREATIVOS (nivel ad individual)
// ─────────────────────────────────────────────

// Cada anuncio individual dentro de una campana
model AdCreative {
  id            String     @id @default(cuid())
  externalId    String                           // ID del ad en Meta/Google
  platform      AdPlatform
  name          String?                          // Nombre del anuncio
  status        String     @default("ACTIVE")    // ACTIVE, PAUSED, DELETED
  createdDate   DateTime?  @db.Date              // Cuando se creo en la plataforma

  // Creative details
  type          String     @default("UNKNOWN")   // IMAGE, VIDEO, CAROUSEL, COLLECTION, RESPONSIVE_SEARCH, RESPONSIVE_DISPLAY
  mediaUrls     String[]                         // URLs de imagenes/videos del creativo
  headline      String?                          // Texto principal del ad
  description   String?                          // Texto secundario
  ctaType       String?                          // CTA: SHOP_NOW, LEARN_MORE, etc.

  // Classification (AI + manual)
  classificationAuto    String?                  // Tipo detectado por IA: UGC, PRODUCT, TESTIMONIAL, LIFESTYLE, PROMO, etc.
  classificationManual  String?                  // Override del usuario
  classificationScore   Float?                   // Confianza de la clasificacion (0-1)

  // Vision Analysis (Claude Vision)
  visionAnalysis        String?                  // JSON completo del analisis visual (colores, objetos, composicion)
  visionClassification  String?                  // Tipo sugerido por Vision (PRODUCT, UGC, LIFESTYLE, etc.)
  visionConfidence      Float?                   // Confianza del analisis visual (0-1)
  visionAnalyzedAt      DateTime?                // Cuando se analizo por ultima vez
  visionError           String?                  // Error si fallo el analisis

  // Relations
  campaignId     String
  campaign       AdCampaign @relation(fields: [campaignId], references: [id])
  adSetId        String?
  adSet          AdSet? @relation("AdSetCreatives", fields: [adSetId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  dailyMetrics   AdCreativeMetricDaily[]
  classifications AdCreativeClassification[]
  pixelAttributions PixelAttribution[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, externalId, platform])
  @@index([adSetId])
  @@index([organizationId, campaignId])
  @@index([organizationId, platform])
  @@map("ad_creatives")
}

// Metricas diarias por anuncio individual
model AdCreativeMetricDaily {
  id              String     @id @default(cuid())
  date            DateTime   @db.Date
  platform        AdPlatform
  impressions     Int        @default(0)
  clicks          Int        @default(0)
  spend           Decimal    @default(0) @db.Decimal(12, 2)
  conversions     Int        @default(0)
  conversionValue Decimal    @default(0) @db.Decimal(12, 2)
  reach           Int?                            // Meta: personas unicas
  frequency       Float?                          // Meta: frecuencia

  // Video engagement metrics (Meta)
  videoPlays      Int?                            // Reproducciones 3+ segundos (thumb stop)
  videoP25Watched Int?                            // Vieron 25% del video
  videoP50Watched Int?                            // Vieron 50% del video
  videoP75Watched Int?                            // Vieron 75% del video
  videoP100Watched Int?                           // Vieron 100% del video

  creativeId      String
  creative        AdCreative @relation(fields: [creativeId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([creativeId, date])
  @@index([organizationId, date])
  @@index([organizationId, platform, date])
  @@map("ad_creative_metrics_daily")
}

// Historial de clasificaciones (audit trail para ML)
model AdCreativeClassification {
  id                    String   @id @default(cuid())
  classificationBefore  String?
  classificationAfter   String
  source                String   // AUTO o MANUAL
  reason                String?  // Por que el usuario cambio la clasificacion

  creativeId     String
  creative       AdCreative @relation(fields: [creativeId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())

  @@index([organizationId, creativeId])
  @@map("ad_creative_classifications")
}

// ─────────────────────────────────────────────
// DATOS WEB (vienen de GA4)
// ─────────────────────────────────────────────

// Métricas web diarias (un registro por día)
model WebMetricDaily {
  id                  String   @id @default(cuid())
  date                DateTime @db.Date
  sessions            Int      @default(0)
  users               Int      @default(0)
  newUsers            Int      @default(0)
  pageViews           Int      @default(0)
  avgSessionDuration  Float?                     // En segundos
  bounceRate          Float?                     // Porcentaje
  source              String?                    // google, facebook, direct, etc.
  medium              String?                    // organic, cpc, referral, etc.
  deviceCategory      String?                    // mobile, desktop, tablet

  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, date])
  @@index([organizationId, source, date])
  @@map("web_metrics_daily")
}

// ─────────────────────────────────────────────
// EMBUDO DE CONVERSIÓN (combinación de GA4 + Ecommerce)
// ─────────────────────────────────────────────

// Datos del embudo por día
model FunnelDaily {
  id                String   @id @default(cuid())
  date              DateTime @db.Date
  visitors          Int      @default(0)         // Paso 1: visitantes únicos
  productViews      Int      @default(0)         // Paso 2: vieron un producto
  addToCarts        Int      @default(0)         // Paso 3: agregaron al carrito
  checkoutStarts    Int      @default(0)         // Paso 4: empezaron checkout
  purchases         Int      @default(0)         // Paso 5: compraron
  source            String?                      // Para filtrar por fuente

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, date])
  @@map("funnel_daily")
}

// ─────────────────────────────────────────────
// BOT DE IA
// ─────────────────────────────────────────────

// Conversaciones con el bot
model BotChat {
  id        String   @id @default(cuid())
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  messages       BotMessage[]

  @@index([organizationId])
  @@map("bot_chats")
}

// Mensajes individuales dentro de un chat
model BotMessage {
  id        String      @id @default(cuid())
  role      MessageRole                          // USER o ASSISTANT
  content   String                               // El texto del mensaje
  metadata  Json?                                // Datos extra (KPIs citados, etc.)
  createdAt DateTime    @default(now())

  chatId    String
  chat      BotChat @relation(fields: [chatId], references: [id])

  @@map("bot_messages")
}

enum MessageRole {
  USER
  ASSISTANT
}

// Memoria persistente del bot — aprendizajes y reglas de negocio
model BotMemory {
  id             String         @id @default(cuid())
  category       MemoryCategory
  title          String
  content        String
  priority       Int            @default(5)         // 0-10, mayor = más importante
  isActive       Boolean        @default(true)
  usageCount     Int            @default(0)
  lastUsedAt     DateTime?
  source         String         @default("MANUAL")  // MANUAL | AUTO_EXTRACTED | SYSTEM
  createdBy      String?                             // Email o "SYSTEM"
  sourceData     Json?                               // Datos extra (ej: chatId de origen)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])

  @@index([organizationId, isActive, priority])
  @@map("bot_memories")
}

enum MemoryCategory {
  BUSINESS_RULE
  CORRECTION
  PREFERENCE
  CONTEXT
}

// Insights automáticos generados por el bot
model Insight {
  id          String       @id @default(cuid())
  type        InsightType
  priority    InsightPriority
  title       String                             // "Tu ROAS en Meta cayó 50%"
  description String                             // Explicación detallada
  action      String                             // Acción recomendada
  metric      String?                            // KPI relacionado
  metricValue Float?                             // Valor actual
  metricDelta Float?                             // Cambio porcentual
  isRead      Boolean      @default(false)
  isDismissed Boolean      @default(false)
  createdAt   DateTime     @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, isRead])
  @@map("insights")
}

enum InsightType {
  ALERT           // Algo salió mal
  OPPORTUNITY     // Hay algo para aprovechar
  TREND           // Tendencia detectada
  RECOMMENDATION  // Sugerencia proactiva
}

enum InsightPriority {
  HIGH
  MEDIUM
  LOW
}

// ─────────────────────────────────────────────
// AURUM USAGE LOG — Telemetria del motor de razonamiento
// ─────────────────────────────────────────────
model AurumUsageLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  mode           String   // "FLASH" | "CORE" | "DEEP"
  model          String   // exact model id used
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  totalTokens    Int      @default(0)
  latencyMs      Int
  toolRounds     Int      @default(0)
  toolsUsed      String[] @default([])
  stopReason     String?
  success        Boolean  @default(true)
  errorMessage   String?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([mode, createdAt])
  @@index([createdAt])
  @@map("aurum_usage_logs")
}

// ─────────────────────────────────────────────
// NITROPIXEL — Tracking first-party
// ─────────────────────────────────────────────

enum AttributionModel {
  LAST_CLICK
  FIRST_CLICK
  LINEAR
  TIME_DECAY
  NITRO
}

// Cada visitante unico identificado por el pixel
model PixelVisitor {
  id              String    @id @default(cuid())
  visitorId       String                          // UUID del cookie _np_vid
  email           String?                         // Cuando se identifica (checkout, login)
  firstSeenAt     DateTime  @default(now()) @db.Timestamptz
  lastSeenAt      DateTime  @default(now()) @db.Timestamptz
  totalSessions   Int       @default(1)
  totalPageViews  Int       @default(0)
  deviceTypes     String[]  @default([])          // ["mobile", "desktop"]
  clickIds        Json?                           // { fbclid, gclid, ttclid, last_utm_source, last_utm_medium, last_utm_campaign }
  country         String?
  region          String?
  fingerprintHash String?                         // Browser fingerprint hash (data-only, NOT used for merge)

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])

  events          PixelEvent[]
  aliases         PixelVisitorAlias[]
  attributions    PixelAttribution[]

  @@unique([organizationId, visitorId])
  @@index([organizationId, email])
  @@index([organizationId, lastSeenAt])
  @@index([organizationId, fingerprintHash])
  @@map("pixel_visitors")
}

// Alias para merge de identidades cross-device
model PixelVisitorAlias {
  id              String   @id @default(cuid())
  oldVisitorId    String                          // El visitor_id que se mergeo
  createdAt       DateTime @default(now())

  visitorId       String
  visitor         PixelVisitor @relation(fields: [visitorId], references: [id])

  @@unique([oldVisitorId])
  @@map("pixel_visitor_aliases")
}

// Cada evento capturado por el pixel
model PixelEvent {
  id              String    @id @default(cuid())
  type            String                          // PAGE_VIEW, ADD_TO_CART, PURCHASE, VIEW_PRODUCT, IDENTIFY, CUSTOM
  sessionId       String                          // UUID de la sesion
  pageUrl         String?
  referrer        String?
  props           Json?                           // Datos del evento (item_id, value, order_id, etc.)
  clickIds        Json?                           // { fbclid, gclid } activos al momento del evento
  utmParams       Json?                           // { source, medium, campaign, content, term }
  deviceType      String?                         // mobile, desktop, tablet
  country         String?
  region          String?
  ipHash          String?                         // Hash del IP (para dedup, no PII)
  userAgent       String?
  timestamp       DateTime  @db.Timestamptz       // Timestamp del evento (del cliente)
  receivedAt      DateTime  @default(now()) @db.Timestamptz // Cuando lo recibio el server

  // CAPI status
  capiSent        Boolean   @default(false)       // Se envio a Meta CAPI?
  capiSentAt      DateTime? @db.Timestamptz
  capiEventId     String?                         // Event ID para dedup con Meta Pixel

  visitorId       String
  visitor         PixelVisitor @relation(fields: [visitorId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, type, timestamp])
  @@index([organizationId, sessionId])
  @@index([visitorId, timestamp])
  @@index([organizationId, capiSent])
  @@map("pixel_events")
}

// Atribucion de orders a touchpoints del pixel
model PixelAttribution {
  id                  String           @id @default(cuid())
  model               AttributionModel
  touchpoints         Json                        // [{ timestamp, source, medium, campaign, clickId, page, eventId }]
  touchpointCount     Int              @default(1)
  attributedValue     Decimal          @db.Decimal(12, 2)
  conversionLag       Int?                        // Dias entre primer touch y compra

  orderId             String
  order               Order @relation(fields: [orderId], references: [id])
  visitorId           String
  visitor             PixelVisitor @relation(fields: [visitorId], references: [id])
  campaignId          String?
  campaign            AdCampaign? @relation(fields: [campaignId], references: [id])
  creativeId          String?
  creative            AdCreative? @relation(fields: [creativeId], references: [id])
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  createdAt           DateTime @default(now())
  isAssisted          Boolean  @default(false)          // True if this touchpoint assisted but didn't get last-click credit
  assistedValue       Decimal  @default(0) @db.Decimal(12, 2)  // Revenue attributed as assisted conversion

  @@unique([orderId, model])
  @@index([organizationId, createdAt])
  @@index([campaignId])
  @@index([creativeId])
  @@index([organizationId, isAssisted])
  @@map("pixel_attributions")
}

// ─────────────────────────────────────────────
// DATOS DE SEO (vienen de Google Search Console)
// ─────────────────────────────────────────────

// Datos de keyword + landing page por día (granular)
model SeoQueryDaily {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  keyword         String                          // Search query del usuario en Google
  landingPage     String                          // URL de la página a la que llegó
  device          String   @default("ALL")        // DESKTOP, MOBILE, TABLET, ALL
  country         String   @default("ARG")        // Código de país ISO 3166-1 alpha-3

  impressions     Int      @default(0)            // Veces que apareció en resultados de Google
  clicks          Int      @default(0)            // Clics desde Google
  ctr             Float?                          // Click-through rate (clicks/impressions)
  position        Float?                          // Posición promedio en Google

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, date, keyword, landingPage, device, country])
  @@index([organizationId, date])
  @@index([organizationId, keyword, date])
  @@map("seo_query_daily")
}

// Datos agregados por landing page por día
model SeoPageDaily {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  landingPage     String                          // URL de la página

  impressions     Int      @default(0)
  clicks          Int      @default(0)
  ctr             Float?
  avgPosition     Float?                          // Posición promedio ponderada

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, date, landingPage])
  @@index([organizationId, date])
  @@index([organizationId, landingPage, date])
  @@map("seo_page_daily")
}

// ══════════════════════════════════════════════════════════════
// Competencia — Monitoreo de precios de competidores
// ══════════════════════════════════════════════════════════════

model CompetitorStore {
  id               String   @id @default(cuid())
  name             String                          // "Jugueterias Cody"
  website          String                          // "https://www.cody.com.ar"
  isActive         Boolean  @default(true)
  metaPageId       String?                         // Facebook Page ID (para Meta Ad Library)
  googleAdsDomain  String?                         // Dominio para Google Ads Transparency
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  prices         CompetitorPrice[]
  ads            CompetitorAd[]

  @@index([organizationId])
  @@map("competitor_stores")
}

model CompetitorPrice {
  id             String    @id @default(cuid())
  productUrl     String                          // URL del producto en sitio competidor
  productName    String    @default("")          // Nombre scrapeado
  currentPrice   Decimal   @default(0)           // Último precio
  previousPrice  Decimal?                        // Precio anterior (para detectar cambios)
  currency       String    @default("ARS")
  imageUrl       String?                         // Imagen scrapeada
  lastScrapedAt  DateTime?
  scrapeStatus   String    @default("PENDING")   // PENDING, OK, ERROR
  scrapeError    String?
  scrapedData    Json      @default("[]")        // Historial: [{date, price}]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  competitorId   String
  competitor     CompetitorStore @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  ownProductId   String?
  ownProduct     Product? @relation(fields: [ownProductId], references: [id], onDelete: SetNull)
  competitorEan  String?                          // EAN del producto en tienda competidora
  matchMethod    String?                          // EAN_EXACT | SKU_MATCH | FUZZY_TEXT

  @@index([organizationId])
  @@index([competitorId])
  @@index([ownProductId])
  @@map("competitor_prices")
}

// Anuncios de competidores (Meta Ad Library + Google Ads Transparency)
model CompetitorAd {
  id               String    @id @default(cuid())
  platform         String                          // "meta" | "google"
  adId             String                          // ID externo del anuncio
  adBody           String?   @db.Text              // Texto del anuncio
  adTitle          String?                         // Título/headline
  adImageUrl       String?                         // URL de la imagen/video
  adSnapshotUrl    String?                         // Link al anuncio en Ad Library
  adUrl            String?                         // URL de destino del anuncio
  startDate        DateTime?                       // Cuándo empezó a correr
  endDate          DateTime?                       // Cuándo dejó (null = activo)
  isActive         Boolean   @default(true)
  adType           String?                         // "image" | "video" | "carousel"
  impressionsRange String?                         // Rango estimado de impresiones
  rawData          Json      @default("{}")        // JSON completo de la respuesta
  firstSeenAt      DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  competitorId     String
  competitor       CompetitorStore @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, platform, adId])
  @@index([organizationId])
  @@index([competitorId])
  @@index([isActive])
  @@map("competitor_ads")
}

// ══════════════════════════════════════════════════════════════
// MERCADOLIBRE — Datos del seller (solo lectura desde la API)
// ══════════════════════════════════════════════════════════════

// Publicaciones activas del seller en ML
model MlListing {
  id              String   @id @default(cuid())
  mlItemId        String                           // MLA-123456789
  title           String
  status          String                           // active, paused, closed, under_review
  categoryId      String?
  categoryName    String?
  price           Decimal  @db.Decimal(12, 2)
  originalPrice   Decimal? @db.Decimal(12, 2)      // Precio sin descuento
  currencyId      String   @default("ARS")
  availableQty    Int      @default(0)
  soldQty         Int      @default(0)
  listingType     String?                          // gold_special, gold_pro, gold, etc.
  condition       String?                          // new, used
  permalink       String?
  thumbnailUrl    String?
  freeShipping    Boolean  @default(false)
  fulfillment     String?                          // fulfillment, xd_drop_off, self_service
  healthScore     Float?                           // Health de la publicación (0-1)
  catalogListing  Boolean  @default(false)         // Si está en catálogo ML
  lastSyncAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, mlItemId])
  @@index([organizationId, status])
  @@map("ml_listings")
}

// Preguntas de compradores en publicaciones
model MlQuestion {
  id              String   @id @default(cuid())
  mlQuestionId    String                           // ID de la pregunta en ML
  mlItemId        String                           // Item al que preguntaron
  text            String                           // Texto de la pregunta
  status          String                           // UNANSWERED, ANSWERED, CLOSED_UNANSWERED
  dateCreated     DateTime @db.Timestamptz
  answerText      String?
  answerDate      DateTime? @db.Timestamptz
  fromBuyerId     BigInt?                          // ML buyer user ID (BigInt por IDs nuevos de ML)
  createdAt       DateTime @default(now())

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, mlQuestionId])
  @@index([organizationId, status])
  @@index([organizationId, dateCreated])
  @@map("ml_questions")
}

// Snapshot diario de métricas del seller (reputación, ratings, etc.)
model MlSellerMetricDaily {
  id                  String   @id @default(cuid())
  date                DateTime @db.Date

  // Reputación
  reputationLevel     String?                      // 5_green, 4_light_green, 3_yellow, etc.
  reputationPower     Boolean  @default(false)      // Power seller

  // Métricas de ventas
  totalSales          Int      @default(0)
  completedSales      Int      @default(0)
  cancelledSales      Int      @default(0)

  // Tasas de reclamos
  claimsRate          Float?                       // % de reclamos
  delayedHandlingRate Float?                       // % de envíos tardíos
  cancellationRate    Float?                       // % de cancelaciones por el seller

  // Ratings
  positiveRatings     Int      @default(0)
  negativeRatings     Int      @default(0)
  neutralRatings      Int      @default(0)

  createdAt           DateTime @default(now())

  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, date])
  @@index([organizationId, date])
  @@map("ml_seller_metrics_daily")
}

// Envíos de ML
model MlShipment {
  id              String   @id @default(cuid())
  mlShipmentId    String
  mlOrderId       String?                          // ML order ID
  status          String                           // pending, ready_to_ship, shipped, delivered, not_delivered
  shippingMode    String?                          // me2, custom, not_specified
  logisticType    String?                          // fulfillment, xd_drop_off, self_service
  trackingNumber  String?
  carrier         String?                          // Nombre del carrier
  estimatedDeliveryFrom DateTime? @db.Timestamptz
  estimatedDeliveryTo   DateTime? @db.Timestamptz
  actualDelivery        DateTime? @db.Timestamptz
  receiverCity    String?
  receiverState   String?
  cost            Decimal? @db.Decimal(12, 2)      // Costo del envío
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, mlShipmentId])
  @@index([organizationId, status])
  @@map("ml_shipments")
}

// Métricas diarias de publicidad en ML (Product Ads, Brand Ads, Display)
model MlAdCampaignDaily {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  mlCampaignId    String
  campaignName    String?
  campaignType    String?                          // product_ads, brand_ads, display
  status          String?                          // active, paused

  impressions     Int      @default(0)
  clicks          Int      @default(0)
  spend           Decimal  @default(0) @db.Decimal(12, 2)
  conversions     Int      @default(0)
  conversionValue Decimal  @default(0) @db.Decimal(12, 2)

  createdAt       DateTime @default(now())

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, mlCampaignId, date])
  @@index([organizationId, date])
  @@index([organizationId, campaignType, date])
  @@map("ml_ad_campaigns_daily")
}

// Comisiones y retenciones de ML por orden
model MlCommission {
  id               String   @id @default(cuid())
  mlOrderId        String
  salePrice        Decimal  @db.Decimal(12, 2)
  commissionAmount Decimal  @db.Decimal(12, 2)
  commissionRate   Float                           // Porcentaje de comisión
  shippingCost     Decimal? @db.Decimal(12, 2)
  taxWithholdings  Decimal? @db.Decimal(12, 2)     // Retenciones IIBB/IVA/Ganancias
  netAmount        Decimal  @db.Decimal(12, 2)     // Lo que recibe el seller
  listingType      String?                         // gold_special, gold_pro
  categoryId       String?
  orderDate        DateTime @db.Timestamptz
  createdAt        DateTime @default(now())

  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, mlOrderId])
  @@index([organizationId, orderDate])
  @@map("ml_commissions")
}

// ─────────────────────────────────────────────
// COSTOS MANUALES (ingresados por el usuario)
// ─────────────────────────────────────────────

// Costos que no vienen automáticamente del ecommerce
// Ej: mensajerías, alquiler, sueldos, herramientas, impuestos
// Soporta distintas estructuras: tarifas por envío, sueldos con cargas, porcentajes
model ManualCost {
  id              String   @id @default(cuid())
  category        String                          // "LOGISTICA", "EQUIPO", "PLATAFORMAS", "FISCAL", "INFRAESTRUCTURA", "MARKETING", "MERMA", "OTROS"
  subcategory     String?                         // Agrupador: nombre de mensajería, rol, plataforma
  name            String                          // Nombre del item: "Estándar AMBA", "Juan Pérez", etc.
  serviceCode     String?                         // Código de servicio: "AND-STD-AMBA" (logística)
  amount          Decimal  @db.Decimal(12, 2)     // Monto: tarifa, sueldo bruto, monto fijo, o porcentaje (ej: 3.5 = 3.5%)
  rateType        String   @default("FIXED_MONTHLY")
                           // "FIXED_MONTHLY": monto fijo por mes (default)
                           // "PER_SHIPMENT": tarifa por envío (logística)
                           // "PERCENTAGE": % de una base (fiscal, plataformas, merma)
  rateBase        String?                         // Solo PERCENTAGE: "GROSS_REVENUE", "COGS", "MELI_REVENUE", "VTEX_REVENUE"
  socialCharges   Float?                          // Solo EQUIPO: % cargas sociales sobre bruto (ej: 35 = 35%)
  type            String   @default("FIXED")      // "FIXED" (recurrente) o "VARIABLE"
  month           String                          // "2025-03" — mes al que aplica
  notes           String?                         // Notas opcionales
  isActive        Boolean  @default(true)         // Para desactivar sin borrar
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, month])
  @@index([organizationId, category])
  @@map("manual_costs")
}

// ─────────────────────────────────────────────
// SHIPPING RATES (carrier + service + postal code → cost)
// ─────────────────────────────────────────────

model ShippingRate {
  id              String   @id @default(cuid())
  carrier         String                          // ANDREANI, OCA, CORREO_ARGENTINO, MOTOS_CABA, etc.
  serviceType     String                          // ESTANDAR, EXPRESS, PICKUP, SAME_DAY
  serviceCode     String?                         // Código opcional: AND-STD, OCA-EXP
  postalCodeFrom  String                          // "1000" (individual) o inicio de rango
  postalCodeTo    String?                         // "1999" (fin de rango, null = CP individual)
  cost            Decimal  @db.Decimal(12, 2)     // Costo por envío en ARS
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, carrier, serviceType])
  @@index([organizationId, postalCodeFrom])
  @@map("shipping_rates")
}

// ─────────────────────────────────────────────
// PREDICTED LTV (pLTV) — Motor de prediccion de valor de cliente
// ─────────────────────────────────────────────
// Almacena predicciones de LTV por cliente.
// El envio a Meta CAPI y Google Ads esta DESACTIVADO por defecto
// (requiere LTV_SEND_ENABLED=true en env para activar).
// Solo funciona con VTEX (tienda propia) — MercadoLibre excluido.

model CustomerLtvPrediction {
  id                  String   @id @default(cuid())
  predictedLtv90d     Decimal  @db.Decimal(12, 2)    // Valor predicho a 90 dias
  predictedLtv365d    Decimal  @db.Decimal(12, 2)    // Valor predicho a 365 dias
  confidence          Float    @default(0)           // 0-1, mas compras = mas confianza
  acquisitionChannel  String                          // Canal de primera compra (Google Ads, Meta Ads, etc.)
  segmentBucket       String                          // "high_value", "medium_value", "low_value"
  inputFeatures       Json     @default("{}")         // Snapshot de datos usados para predecir
  sentToMeta          Boolean  @default(false)        // Se envio a Meta CAPI?
  sentToMetaAt        DateTime?                       // Cuando se envio
  sentToGoogle        Boolean  @default(false)        // Se envio a Google Ads?
  sentToGoogleAt      DateTime?                       // Cuando se envio
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  customerId          String
  customer            Customer @relation(fields: [customerId], references: [id])
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])

  @@unique([customerId, organizationId])
  @@index([organizationId, segmentBucket])
  @@index([organizationId, sentToMeta])
  @@index([organizationId, sentToGoogle])
  @@map("customer_ltv_predictions")
}

// ─────────────────────────────────────────────
// INFLUENCER MARKETING
// ─────────────────────────────────────────────

// Cada influencer vinculado a una organización
model Influencer {
  id                      String    @id @default(cuid())
  code                    String                           // Código único de tracking (ej: "sofia123")
  name                    String                           // Nombre del influencer
  email                   String?                          // Email de contacto
  commissionPercent       Decimal   @db.Decimal(5, 2)     // 0.00 a 100.00
  status                  String    @default("ACTIVE")     // ACTIVE, PAUSED, INACTIVE
  publicName              String?                          // Nombre visible en dashboard público
  profileImage            String?                          // URL de avatar
  isPublicDashboardEnabled Boolean  @default(true)         // Si el dashboard público está activo
  isProductBreakdownEnabled Boolean @default(false)        // Si el influencer puede ver desglose de productos en su dashboard
  dashboardPassword       String?                          // Contraseña para acceder al dashboard público (hashed)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id])
  campaigns               InfluencerCampaign[]
  attributions            InfluencerAttribution[]
  coupons                 InfluencerCoupon[]
  commissionTiers         InfluencerCommissionTier[]
  briefings               InfluencerBriefing[]
  contentSubmissions      ContentSubmission[]
  productSeedings         ProductSeeding[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("influencers")
}

// Aplicaciones públicas de influencers que quieren unirse al programa
model InfluencerApplication {
  id              String    @id @default(cuid())
  name            String
  email           String
  instagram       String?
  tiktok          String?
  youtube         String?
  followers       String?                          // Rango: "1K-10K", "10K-50K", etc.
  message         String?                          // Por qué quiere ser embajador
  status          String    @default("PENDING")    // PENDING, APPROVED, REJECTED
  reviewedAt      DateTime?
  notes           String?                          // Notas internas del admin
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, status])
  @@map("influencer_applications")
}

// Campañas específicas de un influencer
model InfluencerCampaign {
  id              String    @id @default(cuid())
  name            String
  status          String    @default("ACTIVE")     // ACTIVE, PAUSED, COMPLETED
  startDate       DateTime  @db.Date
  endDate         DateTime? @db.Date
  description     String?
  bonusAmount     Decimal?  @db.Decimal(12, 2)    // Monto fijo de bono al alcanzar el target
  bonusTarget     Decimal?  @db.Decimal(12, 2)    // Revenue target para desbloquear el bono
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  influencerId    String
  influencer      Influencer @relation(fields: [influencerId], references: [id])
  attributions    InfluencerAttribution[]
  briefings       InfluencerBriefing[]

  @@index([organizationId, influencerId])
  @@map("influencer_campaigns")
}

// Atribución de una orden a un influencer
model InfluencerAttribution {
  id                  String   @id @default(cuid())
  attributedValue     Decimal  @db.Decimal(12, 2)      // Revenue atribuido
  commissionAmount    Decimal  @db.Decimal(12, 2)      // Comisión calculada
  attributionModel    String   @default("LAST_CLICK")  // Modelo usado
  attributionSource   String   @default("UTM")         // UTM o COUPON
  touchpoints         Json?                             // Copia de touchpoints del pixel
  pixelAttributionId  String?                           // Link a PixelAttribution para auditoría
  createdAt           DateTime @default(now())

  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  orderId             String
  order               Order @relation(fields: [orderId], references: [id])
  influencerId        String
  influencer          Influencer @relation(fields: [influencerId], references: [id])
  campaignId          String?
  campaign            InfluencerCampaign? @relation(fields: [campaignId], references: [id])

  @@unique([orderId, influencerId])
  @@index([organizationId, influencerId, createdAt])
  @@index([organizationId, campaignId])
  @@map("influencer_attributions")
}

// Códigos de cupón vinculados a influencers
model InfluencerCoupon {
  id              String   @id @default(cuid())
  code            String                               // Código de descuento (ej: "SOFIA10")
  discountPercent Decimal? @db.Decimal(5, 2)           // % descuento
  discountFixed   Decimal? @db.Decimal(12, 2)          // Monto fijo descuento
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  influencerId    String
  influencer      Influencer @relation(fields: [influencerId], references: [id])

  @@unique([organizationId, code])
  @@index([organizationId, influencerId])
  @@map("influencer_coupons")
}

// Tiers de comisión por volumen de ventas
model InfluencerCommissionTier {
  id                String   @id @default(cuid())
  minRevenue        Decimal  @db.Decimal(12, 2)    // Revenue mínimo para este tier
  maxRevenue        Decimal? @db.Decimal(12, 2)    // Revenue máximo (null = sin tope)
  commissionPercent Decimal  @db.Decimal(5, 2)     // % comisión en este tier
  label             String?                         // Etiqueta descriptiva (ej: "Bronce", "Plata", "Oro")
  createdAt         DateTime @default(now())

  influencerId      String
  influencer        Influencer @relation(fields: [influencerId], references: [id])

  @@index([influencerId])
  @@map("influencer_commission_tiers")
}

// ─────────────────────────────────────────────
// PHASE 5: CONTENIDO, UGC & PRODUCT SEEDING
// ─────────────────────────────────────────────

// Brief de contenido que la empresa envía al influencer
model InfluencerBriefing {
  id              String    @id @default(cuid())
  title           String                               // "Reel para Día del Niño"
  description     String    @db.Text                   // Instrucciones detalladas
  type            String    @default("GENERAL")        // GENERAL, REEL, STORY, POST, UNBOXING, REVIEW
  deadline        DateTime? @db.Date                   // Fecha límite de entrega
  status          String    @default("ACTIVE")         // ACTIVE, COMPLETED, CANCELLED
  requirements    String?   @db.Text                   // Requerimientos técnicos (formato, duración, etc.)
  hashtags        String?                              // Hashtags sugeridos separados por coma
  mentions        String?                              // Cuentas a mencionar
  dos             String?   @db.Text                   // Lo que SÍ hacer
  donts           String?   @db.Text                   // Lo que NO hacer
  referenceUrls   String?   @db.Text                   // Links de referencia separados por línea
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  influencerId    String?                              // null = briefing para todos los influencers
  influencer      Influencer? @relation(fields: [influencerId], references: [id])
  campaignId      String?
  campaign        InfluencerCampaign? @relation(fields: [campaignId], references: [id])
  submissions     ContentSubmission[]
  seedings        ProductSeeding[]

  @@index([organizationId, status])
  @@index([organizationId, influencerId])
  @@map("influencer_briefings")
}

// Contenido subido por el influencer (puede o no estar ligado a un briefing)
model ContentSubmission {
  id              String    @id @default(cuid())
  type            String    @default("POST")           // REEL, STORY, POST, TIKTOK, YOUTUBE, OTHER
  platform        String    @default("INSTAGRAM")      // INSTAGRAM, TIKTOK, YOUTUBE, OTHER
  contentUrl      String                               // URL del contenido publicado
  caption         String?   @db.Text                   // Caption/descripción que usó
  thumbnailUrl    String?                              // Preview image URL
  notes           String?   @db.Text                   // Notas del influencer
  status          String    @default("PENDING")        // PENDING, APPROVED, REVISION, REJECTED
  reviewNotes     String?   @db.Text                   // Feedback de la empresa
  reviewedAt      DateTime?
  publishedAt     DateTime?                            // Cuándo se publicó el contenido
  metrics         Json?                                // { views, likes, comments, shares, saves }
  isUGC           Boolean   @default(false)            // Marcado como apto para reutilizar como UGC
  ugcApprovedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  influencerId    String
  influencer      Influencer @relation(fields: [influencerId], references: [id])
  briefingId      String?
  briefing        InfluencerBriefing? @relation(fields: [briefingId], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, influencerId])
  @@index([organizationId, isUGC])
  @@map("content_submissions")
}

// Productos enviados a influencers (product seeding / gifting)
model ProductSeeding {
  id              String    @id @default(cuid())
  status          String    @default("PENDING")        // PENDING, SHIPPED, DELIVERED, CONTENT_RECEIVED
  trackingNumber  String?                              // Nro de seguimiento del envío
  shippedAt       DateTime?
  deliveredAt     DateTime?
  notes           String?   @db.Text                   // Notas internas
  estimatedValue  Decimal?  @db.Decimal(12, 2)         // Valor estimado del producto enviado
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  influencerId    String
  influencer      Influencer @relation(fields: [influencerId], references: [id])
  productId       String?
  product         Product? @relation(fields: [productId], references: [id])
  briefingId      String?
  briefing        InfluencerBriefing? @relation(fields: [briefingId], references: [id])

  @@index([organizationId, influencerId])
  @@index([organizationId, status])
  @@map("product_seedings")
}

// ─────────────────────────────────────────────
// AUDIENCE SYNC (Meta Custom Audiences + Google Customer Match)
// ─────────────────────────────────────────────

// Cada audiencia configurada para sincronizar
model Audience {
  id              String    @id @default(cuid())
  name            String                          // "Champions - Meta Lookalike"
  description     String?   @db.Text              // Descripción libre
  platform        String                          // "META" | "GOOGLE" | "BOTH"
  status          String    @default("DRAFT")     // DRAFT, ACTIVE, SYNCING, PAUSED, ERROR
  // Criterios de segmentación (JSON flexible)
  segmentType     String                          // "RFM" | "LTV" | "CUSTOM" | "ALL_CUSTOMERS"
  segmentCriteria Json      @default("{}")        // { rfmSegments: ["Champions","Leales"], ltvBuckets: ["high_value"], minOrders: 2, minSpent: 50000, recencyDays: 90, city: "Buenos Aires", ... }
  // Resultados de matching
  customerCount   Int       @default(0)           // Total de clientes que matchean los criterios
  lastSyncedCount Int       @default(0)           // Cuántos se enviaron en último sync
  // IDs externos de la audiencia en plataformas
  metaAudienceId  String?                         // ID de Custom Audience en Meta
  googleListId    String?                         // ID de User List en Google Ads
  // Health metrics
  metaMatchRate   Float?                          // % de match en Meta (0-100)
  googleMatchRate Float?                          // % de match en Google (0-100)
  // Sync config
  autoSync        Boolean   @default(false)       // Sincronizar automáticamente
  syncFrequency   String    @default("DAILY")     // "HOURLY" | "DAILY" | "WEEKLY" | "MANUAL"
  lastSyncAt      DateTime?
  lastSyncError   String?   @db.Text
  nextSyncAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  syncLogs        AudienceSyncLog[]

  @@index([organizationId, status])
  @@index([organizationId, platform])
  @@map("audiences")
}

// Log de cada sincronización ejecutada
model AudienceSyncLog {
  id              String    @id @default(cuid())
  action          String                          // "FULL_SYNC" | "INCREMENTAL" | "REMOVE"
  platform        String                          // "META" | "GOOGLE"
  status          String                          // "SUCCESS" | "PARTIAL" | "ERROR"
  customersTotal  Int       @default(0)           // Total que matcheó los criterios
  customersSent   Int       @default(0)           // Cuántos se enviaron
  matchRate       Float?                          // Match rate reportado por la plataforma
  errorMessage    String?   @db.Text
  durationMs      Int?                            // Cuánto tardó el sync
  metadata        Json      @default("{}")        // Detalles extra: { batchCount, sessionId, etc }
  createdAt       DateTime  @default(now())

  audienceId      String
  audience        Audience  @relation(fields: [audienceId], references: [id], onDelete: Cascade)

  @@index([audienceId, createdAt])
  @@map("audience_sync_logs")
}
