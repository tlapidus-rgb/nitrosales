# ══════════════════════════════════════════════
# NITROSALES - Variables de Entorno
# ══════════════════════════════════════════════
# Copiá este archivo como .env.local y completá con tus valores reales
# NUNCA subas .env.local a Git (ya está en .gitignore)

# ── Base de Datos ──
DATABASE_URL="postgresql://usuario:password@localhost:5432/nitrosales"

# ── Autenticación (NextAuth) ──
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generar-un-string-secreto-aleatorio-largo"

# ── VTEX ──
VTEX_ACCOUNT_NAME="elmundodeljuguete"
VTEX_APP_KEY="tu-vtex-app-key"
VTEX_APP_TOKEN="tu-vtex-app-token"

# ── Google Analytics 4 ──
GA4_PROPERTY_ID="123456789"
GA4_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"..."}'

# ── Google Ads ──
GOOGLE_ADS_CLIENT_ID="tu-oauth-client-id.apps.googleusercontent.com"
GOOGLE_ADS_CLIENT_SECRET="tu-oauth-client-secret"
GOOGLE_ADS_DEVELOPER_TOKEN="tu-developer-token"
GOOGLE_ADS_CUSTOMER_ID="123-456-7890"
GOOGLE_ADS_REFRESH_TOKEN=""

# ── Meta Ads ──
META_APP_ID="tu-meta-app-id"
META_APP_SECRET="tu-meta-app-secret"
META_ACCESS_TOKEN="tu-access-token-de-larga-duracion"
META_AD_ACCOUNT_ID="act_123456789"

# ── Bot de IA (Anthropic Claude) ──
ANTHROPIC_API_KEY="sk-ant-tu-api-key"

# ── Redis (caché - opcional para MVP) ──
# REDIS_URL="redis://localhost:6379"
